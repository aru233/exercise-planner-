# --- secrets ---
# .env holds GEMINI_API_KEY — never commit it.
.env
.env.local
.env.*.local

# --- python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- virtualenvs ---
.venv/
venv/
env/

# --- runtime data written by the server ---
# These are regenerated every run.  Keep the empty dirs (.gitkeep) so the
# layout is preserved when the repo is freshly cloned.
data/*.json
logs/*.log

# Prefab dashboard is regenerated by live_demo.py on every tool call.
_dashboard.py

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
